{
  "name": "unyform-docs",
  "version": "1.0.0",
  "description": "PDF compilation for unyform.ai documentation",
  "type": "module",
  "scripts": {
    "compile": "tsx compile.ts",
    "compile:all": "tsx compile.ts --all",
    "compile:whitepaper": "tsx compile.ts --doc=whitepaper",
    "compile:executive": "tsx compile.ts --doc=executive-summary",
