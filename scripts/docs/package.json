    "compile:pitch": "tsx compile.ts --doc=pitch-deck"
  },
  "dependencies": {
    "@mermaid-js/mermaid-cli": "^10.6.1",
    "tsx": "^4.7.0",
    "gray-matter": "^4.0.3",
    "glob": "^10.3.10"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  }
}
