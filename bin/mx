#!/bin/bash
#
# mx - MechCrate Project Scaffolding Tool
# Crate Raccoon is unpacking your stack.
#

set -e

VERSION="0.1.0"

# ─────────────────────────────────────────────────────────────────────────────
# Resolve symlinks to find actual script location
# This is critical for finding the lib/ directory when mx is symlinked
# (e.g., from /usr/local/bin/mx -> /path/to/mech-crate/bin/mx)
# ─────────────────────────────────────────────────────────────────────────────
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
    DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    # If SOURCE was a relative symlink, resolve it relative to the symlink's directory
    [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
MECH_CRATE_ROOT="$(dirname "$SCRIPT_DIR")"
TEMPLATES_DIR="$MECH_CRATE_ROOT/templates"
LIB_DIR="$SCRIPT_DIR/lib"

# ─────────────────────────────────────────────────────────────────────────────
# Source all library modules
# ─────────────────────────────────────────────────────────────────────────────
source "$LIB_DIR/common.sh"
source "$LIB_DIR/help.sh"
source "$LIB_DIR/recipe.sh"
source "$LIB_DIR/new.sh"
source "$LIB_DIR/add.sh"
source "$LIB_DIR/upgrade.sh"
source "$LIB_DIR/doctor.sh"
source "$LIB_DIR/infra.sh"
source "$LIB_DIR/cloudflare.sh"
source "$LIB_DIR/build.sh"
source "$LIB_DIR/init-code-rules.sh"
source "$LIB_DIR/test.sh"
source "$LIB_DIR/router.sh"
source "$LIB_DIR/mcp.sh"

# ─────────────────────────────────────────────────────────────────────────────
# Main command router
# ─────────────────────────────────────────────────────────────────────────────
main() {
    local command="${1:-help}"
    shift 2>/dev/null || true
    
    case "$command" in
        new)
            create_project "$@"
            ;;
        upgrade)
            upgrade_project "$@"
            ;;
        add)
            add_service "$@"
            ;;
        recipes)
            recipes_cmd "$@"
            ;;
        infra)
            infra_cmd "$@"
            ;;
        cf|cloudflare)
            cloudflare_cmd "$@"
            ;;
        router)
            router_cmd "$@"
            ;;
        mcp)
            mcp_cmd "$@"
            ;;
        build)
            build_cmd "$@"
            ;;
        icr|init-code-rules)
            init_code_rules_cmd "$@"
            ;;
        test)
            test_cmd "$@"
            ;;
        doctor)
            doctor
            ;;
        version|--version|-v)
            show_version
            ;;
        help|--help|-h)
            show_help
            ;;
        # Proxy commands to make
        dev|up|down|logs|restart|sh|ps|start|stop)
            proxy_to_make "$command" "$@"
            ;;
        *)
            error "Unknown command: $command. Run 'mx help' for usage."
            ;;
    esac
}

main "$@"
