---
import Layout from '@/layouts/Layout.astro';
import Button from '@/components/ui/Button.vue';
import { ArrowLeft, Home } from 'lucide-vue-next';
---

<Layout title="404 - Page Not Found">
  <div class="min-h-screen flex items-center justify-center px-4">
    <div class="text-center">
      <!-- 404 Number -->
      <div class="text-display-large font-bold text-gradient-primary mb-4">
        404
      </div>
      
      <!-- Message -->
      <h1 class="text-headline font-semibold text-foreground mb-4">
        Page not found
      </h1>
      <p class="text-body-large text-muted-foreground max-w-md mx-auto mb-8">
        Sorry, we couldn't find the page you're looking for. 
        It might have been moved or doesn't exist.
      </p>
      
      <!-- Actions -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/">
          <Button size="lg" class="w-full sm:w-auto">
            <Home client:load class="w-4 h-4 mr-2" />
            Go home
          </Button>
        </a>
        <Button 
          variant="outline" 
          size="lg" 
          onclick="history.back()"
          client:load
        >
          <ArrowLeft class="w-4 h-4 mr-2" />
          Go back
        </Button>
      </div>
    </div>
  </div>
</Layout>
