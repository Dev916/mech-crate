FROM rust:1.91.1

ARG IMAGE_VERSION
ENV IMAGE_VERSION=$IMAGE_VERSION

LABEL image.name="pro-api"
LABEL image.version="$IMAGE_VERSION"

ARG IMAGE_TAG
ENV IMAGE_TAG=$IMAGE_TAG
LABEL image.tag="$IMAGE_TAG"

RUN mkdir -p /srv/app

RUN cargo install cargo-watch \
    && cargo install sqlx-cli --no-default-features --features rustls,postgres

WORKDIR /srv/app

RUN apt-get update && apt-get install -y --no-install-recommends \
    haproxy \
    supervisor \
    netcat-traditional \
    jq \
    postgresql-client \
    && rm -rf /var/lib/apt/lists/*

COPY ./apps/pro-api/Cargo.toml ./
COPY ./apps/pro-api/Cargo.lock ./

COPY ./apps/pro-api .

COPY docker/system/pro-api /
COPY docker/system/shared /

RUN mkdir -p /run/haproxy && touch /run/haproxy/admin.sock

RUN build-server

ENTRYPOINT [ "/entrypoint" ]
