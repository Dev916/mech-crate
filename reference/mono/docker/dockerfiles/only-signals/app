FROM rust:1.86

ARG IMAGE_VERSION
ENV IMAGE_VERSION=$IMAGE_VERSION

LABEL image.name="only-signals"
LABEL image.version="$IMAGE_VERSION"

ARG IMAGE_TAG
ENV IMAGE_TAG=$IMAGE_TAG
LABEL image.tag="$IMAGE_TAG"

# Install Node.js 20 and other dependencies
RUN apt-get update && \
    apt-get install -y curl && \
    curl -fsSL https://deb.nodesource.com/setup_20.x | bash - && \
    apt-get install -y nodejs && \
    npm install -g yarn && \
    apt-get install -y --no-install-recommends haproxy supervisor jq && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# [removed cargo-watch installation to reduce build time]
RUN cargo install cargo-watch

# Create app directory
RUN mkdir -p /srv/app

WORKDIR /srv/app

# Copy and build Rust backend
COPY ./apps/only-signals/app/backend/Cargo.toml ./backend/
COPY ./apps/only-signals/app/backend/Cargo.lock ./backend/
COPY ./apps/only-signals/app/backend ./backend/

# Copy frontend files
COPY ./apps/only-signals/app/frontend ./frontend/

# Copy system files
COPY docker/system/only-signals /

# Create required directories
RUN mkdir -p /run/haproxy && touch /run/haproxy/admin.sock
RUN mkdir -p /var/log/supervisor

# Build Rust backend
RUN cd backend && cargo build --release

# Install frontend dependencies and build
RUN cd frontend && \
    yarn install --network-timeout=99999 && \
    yarn build

# Set permissions
RUN chown -R nobody:nobody /srv/app/frontend/.nuxt || true
RUN chown -R nobody:nobody /srv/app/frontend/.output || true

EXPOSE 80

ENTRYPOINT [ "/entrypoint" ]