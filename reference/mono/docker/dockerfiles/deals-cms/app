FROM python:3.12.2-alpine3.18

ARG IMAGE_TAG
ARG COMMIT_HASH
ARG IMAGE_VERSION
ARG TBLK_VERSION

ENV APP_ROOT=/srv/app
ENV HOST=0.0.0.0
ENV IMAGE_VERSION=${IMAGE_VERSION}
ENV IMAGE_TAG=${IMAGE_TAG}

RUN apk add --update --no-cache linux-headers postgresql-dev openblas-dev gcc g++ cmake make gfortran python3-dev \
    py3-scipy musl-dev haproxy jq sudo supervisor

WORKDIR /srv/app

COPY docker/app /

COPY admin /srv/app/admin
COPY app /srv/app/app
COPY charts /srv/app/charts
COPY cms /srv/app/cms
COPY Makefile /srv/app/Makefile
COPY manage.py /srv/app/manage.py
COPY shared /srv/app/shared
COPY requirements.txt /srv/app/requirements.txt
COPY templates /srv/app/templates

RUN python -m pip install Django gunicorn uvicorn

RUN set -ex &&
    pip3 install -r requirements.txt

COPY docker/entrypoints/app /bin/entrypoint

RUN chmod +x /bin/entrypoint

ENTRYPOINT ["/bin/entrypoint"]
