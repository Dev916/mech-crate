ARG BASE_IMAGE=ghcr.io/theblockcrypto/deals-cms:local

FROM $BASE_IMAGE

COPY apps/deals-cms/docker/app /

COPY apps/deals-cms/admin /srv/app/admin
COPY apps/deals-cms/app /srv/app/app
COPY apps/deals-cms/charts /srv/app/charts
COPY apps/deals-cms/cms /srv/app/cms
COPY apps/deals-cms/Makefile /srv/app/Makefile
COPY apps/deals-cms/manage.py /srv/app/manage.py
COPY apps/deals-cms/shared /srv/app/shared
COPY apps/deals-cms/requirements.txt /srv/app/requirements.txt
COPY apps/deals-cms/templates /srv/app/templates

COPY docker/entrypoints/app /bin/entrypoint

RUN chmod +x /bin/entrypoint

ENTRYPOINT ["/bin/entrypoint"]
