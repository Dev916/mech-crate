FROM rust:1.91.1

ARG IMAGE_VERSION
ENV IMAGE_VERSION=$IMAGE_VERSION

LABEL image.name="priority-api"
LABEL image.version="$IMAGE_VERSION"

ARG IMAGE_TAG
ENV IMAGE_TAG=$IMAGE_TAG
LABEL image.tag="$IMAGE_TAG"

RUN mkdir -p /srv/app

RUN cargo install cargo-watch cargo-leptos

WORKDIR /srv/app

RUN apt-get update && apt-get install -y --no-install-recommends haproxy supervisor jq && rm -rf /var/lib/apt/lists/*

COPY ./apps/priority-api/Cargo.toml ./
COPY ./apps/priority-api/Cargo.lock ./

COPY ./apps/priority-api .

RUN cd priority-api-docs && rustup target add wasm32-unknown-unknown

COPY docker/system/priority-api /

RUN mkdir -p /run/haproxy && touch /run/haproxy/admin.sock

RUN build-server

ENTRYPOINT [ "/entrypoint" ]
