FROM ghcr.io/theblockcrypto/wordpress-base-php8:latest
LABEL image.name="wordpress"

COPY --chown=www-data:www-data ./docker/system/WordPress /

COPY --chown=www-data:www-data ./apps/WordPress/.env.defaults /srv/wp/.env.defaults
COPY --chown=www-data:www-data ./apps/WordPress/.env.defaults /srv/wp/.env

COPY --chown=www-data:www-data ./composer.* /srv/wp/

COPY --chown=www-data:www-data ./apps/WordPress/php /srv/wp/php
COPY --chown=www-data:www-data ./apps/WordPress/wp-content /srv/wp/wp-content
COPY --chown=www-data:www-data ./apps/WordPress/wp-config.php /srv/wp/wp-config.php
COPY --chown=www-data:www-data ./apps/WordPress/db-config.php /srv/wp/db-config.php
COPY --chown=www-data:www-data ./apps/WordPress/errors/400.html /srv/wp/errors/400.html
COPY --chown=www-data:www-data ./apps/WordPress/errors/500.html /srv/wp/errors/500.html

RUN docker-php-ext-install -j$(nproc) pcntl

RUN composer-install

ARG TBLK_VERSION
ENV TBLK_VERSION=$TBLK_VERSION
ENV DD_VERSION=$TBLK_VERSION
LABEL image.version="$TBLK_VERSION"
LABEL com.datadoghq.tags.version="$TBLK_VERSION"

ARG IMAGE_TAG
LABEL image.tag="$IMAGE_TAG"

EXPOSE 80

CMD [ "/entrypoint" ]
