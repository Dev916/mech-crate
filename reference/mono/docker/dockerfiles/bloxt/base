# Start from openresty alpine: https://github.com/openresty/docker-openresty/tree/master/alpine
FROM node:16-alpine

ENV APP_ROOT=/srv/app \
    HOST=0.0.0.0 \
    NPM_CONFIG_LOGLEVEL=warn

WORKDIR $APP_ROOT
EXPOSE 80
ENTRYPOINT [ "/entrypoint" ]

RUN apk add --no-cache jq nginx nodejs sudo supervisor yarn git

RUN mkdir /var/log/supervisor &&
    ln -sf /dev/stdout /var/log/nginx/access.log &&
    ln -sf /dev/stderr /var/log/nginx/error.log &&
    ln -sf /dev/stdout /var/log/nginx/tblk.us-access.log &&
    ln -sf /dev/stderr /var/log/nginx/tblk.us-error.log &&
    ln -sf /dev/stdout /var/log/nginx/local-access.log &&
    ln -sf /dev/stderr /var/log/nginx/local-error.log &&
    rm -rf /etc/nginx/sites-enabled/

RUN yarn global add merge-packages --prefix /usr/local

COPY --chown=nobody:nobody ./.env.defaults $APP_ROOT/
COPY --chown=nobody:nobody ./.github $APP_ROOT/
COPY --chown=nobody:nobody ./.npmrc $APP_ROOT/
COPY --chown=nobody:nobody ./package.json $APP_ROOT/
COPY --chown=nobody:nobody ./core/package.json $APP_ROOT/core/package.json
COPY --chown=nobody:nobody ./yarn.lock $APP_ROOT/

COPY --chown=nobody:nobody ./.npmrc /
COPY --chown=nobody:nobody ./package.json /
COPY --chown=nobody:nobody ./core/package.json /package-core.json
COPY --chown=nobody:nobody ./yarn.lock /

COPY ./docker /

RUN yarn-install
