ARG BASE_IMAGE=node:20-alpine

FROM $BASE_IMAGE

ARG IMAGE_TAG
ARG IMAGE_VERSION
ARG NODE_ENV
ARG TBLK_VERSION

ENV APP_ROOT=/srv/app
ENV HOST=0.0.0.0
ENV IMAGE_VERSION=${IMAGE_VERSION}
ENV NPM_CONFIG_LOGLEVEL=warn
ENV NODE_ENV=${NODE_ENV:-production}
ENV COMMIT_SHA_FRONT=${COMMIT_SHA_FRONT:-${IMAGE_VERSION}}

LABEL image.name="theblock.pro"
LABEL image.version="$IMAGE_VERSION"
LABEL image.tag="$IMAGE_TAG"

WORKDIR $APP_ROOT
EXPOSE 80
ENTRYPOINT [ "/entrypoint" ]

RUN apk add --no-cache jq haproxy sudo supervisor yarn git make g++

RUN mkdir -p /var/log/supervisor

RUN yarn global add merge-packages tsx --prefix /usr/local

COPY ./docker/system/theblock.pro /

COPY --chown=nobody:nobody ./apps/theblock.pro .

COPY --chown=nobody:nobody ./apps/theblock.pro/.npmrc $APP_ROOT/
COPY --chown=nobody:nobody ./apps/theblock.pro/package.json $APP_ROOT/
COPY --chown=nobody:nobody ./apps/theblock.pro/yarn.lock $APP_ROOT/

RUN NODE_OPTIONS=--max-old-space-size=4096 yarn-install -b

RUN chown -R nobody:nobody $APP_ROOT/.nuxt
