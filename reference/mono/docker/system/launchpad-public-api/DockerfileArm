# Start from openresty alpine: https://github.com/openresty/docker-openresty/tree/master/alpine
FROM ghcr.io/theblockcrypto/bloxt-arm:latest

COPY --chown=nobody:nobody ./.env.defaults $APP_ROOT/
COPY --chown=nobody:nobody ./.npmrc $APP_ROOT/
COPY --chown=nobody:nobody ./package.json $APP_ROOT/
COPY --chown=nobody:nobody ./yarn.lock $APP_ROOT/

COPY --chown=nobody:nobody ./.npmrc /
COPY --chown=nobody:nobody ./package.json /
COPY --chown=nobody:nobody ./yarn.lock /

COPY ./docker /

RUN yarn-install
