#!/bin/sh -e

if [ ! -d /app/ ]; then
  echo "No app source folder found. Exiting."
  exit 0
fi

cp -r /app/* /srv/app/

srcFiles=$(find /app/ -print)

for currentFile in $srcFiles; do
    if [[ $currentFile == *".git"* ]]; then
        continue
    fi

    destFile=/srv$currentFile

    if  [ -f $currentFile ] && [ ! -d $destFile ]; then
        echo "Linking $currentFile to $destFile";
        ln -sf $currentFile $destFile
    fi

    if  [ -d $currentFile ] && [ ! -d $destFile ] && [ ! -f $destFile ]; then
        echo "Linking directory $currentFile to $destFile"
        mkdir -p $destFile
        ln -s $currentFile/* $destFile/
    fi
done