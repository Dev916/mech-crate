#!/bin/sh -e

build=$1

echo -e "\n ##### $(date) #####\n"

set -x

cd "/"

if [ -e /app/package.json ]; then
 echo "Copying /app/package.json"
 cp /app/package.json /
else
 echo "Copying $APP_ROOT/package.json"
 cp $APP_ROOT/package.json /
fi

cp $APP_ROOT/.npmrc /
cp $APP_ROOT/yarn.lock /
cp $APP_ROOT/core/package.json /package-core.json

chown nobody:nobody /yarn.lock

chown nobody:nobody .

merge-packages --output=/package.json /package.json /package-core.json

sudo -u nobody -g nobody touch yarn-error.log

if [ ! -d /.cache/yarn ]; then
    mkdir -p /.cache/yarn /.yarn
    chown -R nobody:nobody /.cache/yarn /.yarn
fi

rm -rf /node_modules/*

yarn cache clean

sudo -u nobody -g nobody UV_THREADPOOL_SIZE=64 NODE_ENV=development yarn install --ignore-engines --force --network-timeout=99999

cd "$APP_ROOT"


ln -s /node_modules $APP_ROOT/node_modules

if [ ! -f "/usr/local/bin/nuxt" ]; then
  rm -rf /usr/local/bin/nuxt
  ln -s /node_modules/.bin/nuxt /usr/local/bin/nuxt
fi

if [ ! -f "/usr/local/bin/ts-node" ]; then
  rm -rf /usr/local/bin/ts-node
  ln -s /node_modules/.bin/ts-node /usr/local/bin/ts-node
fi

if [ ! -f "/usr/local/bin/cross-env" ]; then
  rm -rf /usr/local/bin/cross-env
  ln -s /node_modules/.bin/cross-env /usr/local/bin/cross-env
fi

if [ ! -f "/usr/local/bin/nuxt-storybook" ]; then
  rm -rf /usr/local/bin/nuxt-storybook
  ln -s /node_modules/.bin/nuxt-storybook /usr/local/bin/nuxt-storybook
fi

chown nobody:nobody .
sudo -u nobody -g nobody touch yarn-error.log

rm -rf .nuxt .cache

if [ -n "$build" ]; then
    sudo -u nobody -g nobody yarn build
fi

sudo -u nobody -g nobody yarn list | tr -cd '\000-\177' | sudo -u nobody -g nobody tee $APP_ROOT/static/yarn.list
