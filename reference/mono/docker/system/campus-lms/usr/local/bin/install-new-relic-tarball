#!/bin/sh

# Runtime installer for New Relic PHP agent (Alpine/musl)
# - Fetches latest (or pinned) musl tarball for current arch
# - Installs non-interactively
# - Seeds license and app name in newrelic.ini
#
# Required env:
#   NEW_RELIC_LICENSE_KEY   (preferred; fallback to prompt if missing)
# Optional env:
#   NEW_RELIC_APP_NAME      (default: campus-lms)
#   NEW_RELIC_AGENT_VERSION (pin a specific agent version)
#
# Notes:
# - This script is idempotent when caller checks for existing module/INI.
# - It does not require newrelic-cli or apt/yum.

set -eu

APP_NAME=${NEW_RELIC_APP_NAME:-campus-lms}
PINNED_VER=${NEW_RELIC_AGENT_VERSION:-}
WORKDIR=${NR_TMP_DIR:-/tmp/newrelic-php}

# Always use linux-musl tarballs (provider does not ship arch-specific musl here)
pkg_suffix="linux-musl"

BASE_URL="https://download.newrelic.com/php_agent/release"

mkdir -p "$WORKDIR"
cd "$WORKDIR"

find_latest_url() {
  # Find the newest linux-musl tar.gz
  curl -fsSL "$BASE_URL/" \
    | grep -oE 'newrelic-php5-[0-9]+(\.[0-9]+)*-[^"]*linux-musl\.tar\.gz' \
    | sort -V \
    | tail -n 1 \
    | awk -v base="$BASE_URL" '{print base "/" $1}'
}

resolve_tarball_url() {
  if [ -n "$PINNED_VER" ]; then
    name="newrelic-php5-${PINNED_VER}-linux-musl.tar.gz"
    url="$BASE_URL/$name"
    if curl -fsI "$url" >/dev/null 2>&1; then
      echo "$url"; return 0
    fi
    echo ""; return 0
  else
    find_latest_url
  fi
}

TARBALL_URL=$(resolve_tarball_url)
if [ -z "$TARBALL_URL" ]; then
  echo "[newrelic] Unable to resolve tarball URL (version=$PINNED_VER)" >&2
  exit 0
fi

echo "[newrelic] Downloading agent: $TARBALL_URL"
curl -fsSL "$TARBALL_URL" -o newrelic-php.tar.gz
rm -rf newrelic-php
mkdir -p newrelic-php && tar -xzf newrelic-php.tar.gz -C newrelic-php --strip-components=1

cd newrelic-php

# Silent install; copy instead of linking to avoid issues on Alpine
export NR_INSTALL_SILENT=1
export NR_INSTALL_USE_CP_NOT_LN=1
if ! sudo NR_INSTALL_KEY=${NEW_RELIC_LICENSE_KEY} ./newrelic-install install >/dev/null 2>&1; then
  echo "[newrelic] WARNING: installer returned non-zero; proceeding to seed config if possible" >&2
fi

# Find PHP additional .ini scan dir
SCAN_DIR=$(php -i 2>/dev/null | sed -n 's#^Scan this dir for additional .ini files => \(.*\)$#\1#p' | tail -n1)
if [ -z "$SCAN_DIR" ]; then
  # Fallback for Alpine php82
  if [ -d "/etc/php82/conf.d" ]; then
    SCAN_DIR="/etc/php82/conf.d"
  else
    SCAN_DIR="/usr/local/etc/php/conf.d"
  fi
fi
mkdir -p "$SCAN_DIR"

INI="$SCAN_DIR/newrelic.ini"
if [ ! -f "$INI" ]; then
  # Create minimal INI if installer didn’t write one
  echo "[newrelic] Creating $INI"
  cat > "$INI" <<'EOF'
; New Relic PHP agent
extension = newrelic.so
newrelic.enabled = true
newrelic.distributed_tracing_enabled = true
EOF
fi

# Seed license and app name
if [ -n "${NEW_RELIC_LICENSE_KEY:-}" ]; then
  # Replace placeholder or append
  if grep -q '^\s*newrelic\.license\s*=' "$INI" 2>/dev/null; then
    sed -i "s#^\s*newrelic\.license\s*=.*#newrelic.license = ${NEW_RELIC_LICENSE_KEY}#" "$INI"
  else
    echo "newrelic.license = ${NEW_RELIC_LICENSE_KEY}" >> "$INI"
  fi
else
  echo "[newrelic] WARNING: NEW_RELIC_LICENSE_KEY not set; agent will not report data" >&2
fi

if grep -q '^\s*newrelic\.appname\s*=' "$INI" 2>/dev/null; then
  sed -i "s#^\s*newrelic\.appname\s*=.*#newrelic.appname = ${APP_NAME}#" "$INI"
else
  echo "newrelic.appname = ${APP_NAME}" >> "$INI"
fi

echo "[newrelic] Installed and configured PHP agent (ini: $INI)"
