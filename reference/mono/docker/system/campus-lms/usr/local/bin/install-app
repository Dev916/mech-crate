#!/bin/bash

set -e

APP_DIR=/srv/app
VENDOR_DIR=$APP_DIR/vendor
NODE_MODULES_DIR=$APP_DIR/node_modules
FORCE_INSTALL=$1

echo "Installing app dependencies..."

if [ "$FORCE_INSTALL" = "force" ]; then
    echo "Forcing install"
    rm -rf $VENDOR_DIR
    rm -rf $NODE_MODULES_DIR
fi

if [ -d "$VENDOR_DIR" ]; then
    echo "PHP Dependencies installed, skipping"
else
    echo "Installing PHP Dependencies"
    cd $APP_DIR
    composer install -q --no-ansi --no-interaction --no-scripts --no-suggest --no-progress --prefer-dist
    echo "PHP Dependencies installed"
    php artisan config:cache
fi

if [ -d "$NODE_MODULES_DIR" ]; then
    echo "Node Dependencies installed, skipping"
else
    echo "Installing Node Dependencies"
    cd $APP_DIR
    yarn cache clean
    UV_THREADPOOL_SIZE=64 NODE_ENV=development yarn install --force --network-timeout=99999
    echo "Node Dependencies installed"
fi
