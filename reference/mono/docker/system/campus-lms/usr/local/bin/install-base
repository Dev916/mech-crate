#!/bin/sh

set -e

echo "Installing base dependencies..."

# conditionally add www-data user if it doesn't exist

echo 'http://dl-cdn.alpinelinux.org/alpine/v3.18/main' >/etc/apk/repositories
echo 'http://dl-cdn.alpinelinux.org/alpine/v3.18/community' >>/etc/apk/repositories

apk update

apk cache -v sync

## todo make dev build only
apk add alpine-sdk bash

touch ~/.bashrc

apk add --no-cache --update \
    build-base \
    curl \
    gcc \
    make \
    wget \
    perl \
    which \
    git \
    jq \
    nginx \
    sudo \
    supervisor \
    postgresql15 \
    ca-certificates \
    openssl \
    ncurses \
    coreutils \
    python3 \
    g++ \
    libgcc \
    linux-headers \
    grep \
    util-linux \
    binutils \
    findutils \
    shadow \
    chromium \
    nss \
    freetype \
    harfbuzz \
    ttf-freefont \
    font-noto \
    font-noto-cjk \
    udev \
    ttf-opensans \
    libstdc++

mkdir -p /var/log/supervisor

if
    ! id -u www-data &
    >/dev/null
then
    echo "No www-data user found. Adding www-data user"

    adduser -u 82 -G www-data -h /var/www -s /sbin/nologin -D www-data

    mkdir -p /var/www

    chown -R www-data:www-data /var/www

    chmod -R 755 /var/www
fi
