#!/bin/bash

_forwardTerm () {
    echo "Caught signal SIGTERM, passing it to child processes..."
    pgrep -P $$ | xargs kill -15 2>/dev/null
    wait
    exit $?
}

trap _forwardTerm TERM

LIVE_TEST_WS_URL=wss://priority-api.theblock.pro/api-public/v1/news/live /srv/app/priority-api-docs/target/release/priority-api-docs