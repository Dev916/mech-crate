#!/bin/bash

# Set environment variables
export PGPASSWORD=$SECRETS_postgres_password

# The path to the gzipped SQL dump file to be restored
DUMP_FILE="/tmp/exports/zulip-latest.sql.gz"

# Ensure the dump file exists
if [ ! -f "$DUMP_FILE" ]; then
    echo "Dump file $DUMP_FILE not found!"
    exit 1
fi
DB_NAME="zulip"

# Function to stop all Supervisor-managed services
stop_services() {
    echo "Stopping all Supervisor-managed services..."
    supervisorctl stop all
}

# Function to terminate all connections to the database
terminate_connections() {
    echo "Terminating all connections to the database $DB_NAME..."
    psql -h $DB_HOST -U $DB_USER -d postgres -c "
    SELECT pg_terminate_backend(pid) 
    FROM pg_stat_activity 
    WHERE datname = '$DB_NAME' AND pid <> pg_backend_pid();
  "
}

# Function to start all Supervisor-managed services
start_services() {
    echo "Starting all Supervisor-managed services..."
    supervisorctl start all
}

# Drop the database
drop_database() {
    echo "Dropping the database $DB_NAME..."
    psql -h $DB_HOST -U $DB_USER -d postgres -c "DROP DATABASE IF EXISTS $DB_NAME;"
}

# Create the database
create_database() {
    echo "Creating the database $DB_NAME..."
    psql -h $DB_HOST -U $DB_USER -d postgres -c "CREATE DATABASE $DB_NAME;"
}

# Restore the database from the gzipped SQL dump file
restore_database() {
    echo "Restoring the database $DB_NAME from $DUMP_FILE..."
    gunzip -c "$DUMP_FILE" | psql -h $DB_HOST -U $DB_USER -d $DB_NAME
}

stop_services

terminate_connections

# Drop, create, and restore the database
drop_database
create_database
restore_database

# Check if the restore was successful
if [ $? -eq 0 ]; then
    echo "Database restored successfully from $DUMP_FILE"
else
    echo "Failed to restore the database from $DUMP_FILE"
    start_services
    exit 1
fi

start_services
