#!/bin/sh -e

# Change to the app directory
cd /home/zulip/deployments/current || exit

COMMAND="$1"
shift # Remove the first argument and use the rest as parameters

case "$COMMAND" in
help)
    echo "Available commands:"
    echo "  help        - Show this help message."
    echo "  user        - Create a Django superuser."
    echo "  org         - Create a default organization and user."
    echo "  import      - Import data"
    echo "  init-simon  - Initialize the Simon bot."
    echo "  monitor     - Start the queue monitor using a custom management command."
    echo ""
    echo "Usage: connect <command>"
    echo "Example: connect org"
    ;;
user)
    echo "Creating user..."
    ./manage.py create_user "$@"
    ;;
org)
    echo "Creating organization..."
    ./manage.py create_realm --string-id "simon-realm" --password "$ZULIP_REALM_PASSWORD" simon-realm simon-realm@theblock.pro "Simon AI Realm"
    ./manage.py create_realm --string-id "simon-realm" --password "AP4KXZ75mwKrBF2Qbkw2QuPWLZEL7TUV" simon-realm simon-realm@theblock.pro "Simon AI Realm"

    ;;
import)
    echo "Importing data..."
    ./manage.py import_realm "$@"
    ;;
init-simon)
    echo "Initializing Simon bot..."
    ./manage.py init_simon "$@"
    ;;
monitor)
    ./manage.py queue_processor --queue=loopback --processes=1 --threads=1
    ;;
*)
    echo "Unknown command: $COMMAND"
    echo "Use 'dcms help' to see available commands."
    exit 1
    ;;
esac
