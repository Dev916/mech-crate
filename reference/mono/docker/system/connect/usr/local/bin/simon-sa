#!/bin/bash

cd /srv/simon

# Function to start the Simon Bot
start_simon_bot() {

    stopfile="/tmp/simon.stop"

    # Create the stop file
    touch "$stopfile"

    while [ -f "$stopfile" ]; do
        echo "Starting Simon Bot..."
        python3 bot.py

        echo "Simon bot process ended."
        if [ -f "$stopfile" ]; then
            echo "Restarting..."
        else
            echo "Stopfile removed, not restarting."
        fi
    done
}

start_simon_bot &

wait
