#!/bin/bash

cd /srv/wp/web

dump_src=https://theblockpro-devops.s3.amazonaws.com/wp/db-dumps/payloads.jsonl.gz
dump_file=/tmp/payloads.jsonl.gz

if [ -e "$dump_file" ]; then
  rm -rf "$dump_file"
fi

curl "$dump_src" >"$dump_file"

ls -l /tmp

gunzip -c "$dump_file" >payloads.jsonl

/srv/wp/vendor/bin/wp --allow-root --url=/ payloads import --file=/srv/wp/web/payloads.jsonl
