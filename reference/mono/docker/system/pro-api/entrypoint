#!/bin/bash

cd /srv/app

_forwardTerm () {
    echo "Caught signal SIGTERM, passing it to child processes..."
    pgrep -P $$ | xargs kill -15 2>/dev/null
    wait
    exit $?
}

trap _forwardTerm TERM

_run_migrations() {
  echo "Waiting for PostgreSQL to be ready..."
  wait4service postgres 5432

  echo "PostgreSQL is ready"

  if [ "${RUN_MIGRATIONS:-false}" = "true" ]; then
    echo "📦 Running database migrations..."
    if migrate run; then
      echo "✅ Migrations complete"
    else
      echo "❌ Migration failed!"
      if [ "${MIGRATIONS_REQUIRED:-false}" = "true" ]; then
        echo "MIGRATIONS_REQUIRED=true, exiting..."
        exit 1
      else
        echo "Continuing despite migration failure (set MIGRATIONS_REQUIRED=true to fail on error)"
      fi
    fi
  else
    echo "⏭️  Skipping migrations (set RUN_MIGRATIONS=true to enable)"
  fi
}

_main() {
  
  if [ -n "$DEV_MODE" ]; then
    echo "💻 💻 💻 DEV_MODE is live 💻 💻 💻"
  else
    echo "🚀 🚀 🚀 PROD_MODE is live 🚀 🚀 🚀"
  fi

  # Run migrations if enabled
  _run_migrations

  export API_NUM_PROCS=${API_NUM_PROCS:-1}
  export API_COMMAND=${API_COMMAND:-$([[ -n "$DEV_MODE" ]] && echo "dev-server" || echo "prod-server")}

  procs="$(seq 0 $(($API_NUM_PROCS - 1)))"

  mkdir -p /var/log/supervisor

  for i in $procs; do
    touch "/var/log/supervisor/api-0${i}.log"
    chown nobody:nogroup "/var/log/supervisor/api-0${i}.log"
  done

  touch "/var/log/supervisor/docs.log"
  chown nobody:nogroup "/var/log/supervisor/docs.log"

  touch "/var/log/supervisor/haproxy.log" 
  chown nobody:nogroup "/var/log/supervisor/haproxy.log"

  tail -f /var/log/supervisor/api-*.log &
  tail -f /var/log/supervisor/docs.log &
  tail -f /var/log/supervisor/haproxy.log &

  echo "Starting api and haproxy via supervisor with: API_NUM_PROCS=$API_NUM_PROCS, API_COMMAND=$API_COMMAND ..."

  /usr/bin/supervisord -n -c "/etc/supervisor/conf.d/app.conf"
  
}

if [ $# -eq 0 ]; then
  _main
else
  exec "$@"
fi
