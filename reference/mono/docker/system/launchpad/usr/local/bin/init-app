#!/bin/sh -e

while true; do
    read -p "This initialize an entirely new code-base in the /app directory. Are you sure? " yn
    case $yn in
        [Yy]* ) break;;
        [Nn]* ) exit;;
        * ) echo "Please answer yes or no.";;
    esac
done

echo "Copying source files..."
echo
echo

cp -rf /srv/app/* /app/
cp -rf /srv/app/.github /app/
cp /srv/app/.gitignore /app/
cp /srv/app/.env.defaults /app/.env.defaults

cd /app/

cp -rf ./install/* .
cp -f ./install/.env.defaults .
cp -f ./install/.gitignore .


rm -rf ./install
rm -rf ./core

read -p "Please enter application slug (e.g. next-awesome-launchpad-app): " app_slug

interpolate-source /app/ $app_slug

create-npmrc

if [[ $(uname -m) == 'arm64' ]]; then
  cp /app/docker-compose.override.yml.appledist /app/docker-compose.override.yml;
else
  cp /app/docker-compose.override.yml.dist /app/docker-compose.override.yml;
fi

echo "App initialized! You are good to build and start the local stack now: (eg. ./build-local-images.sh && docker-compose up)"
